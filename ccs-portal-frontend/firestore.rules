rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: uid
    // Fields: uid, email, role, name, photoURL, bio, qualifications, experience, status, lastLogin
    //
    // Collection: courses
    // Document ID: courseId
    // Fields: id, title, description, facultyId, facultyName, published, skills, duration, thumbnail, createdAt
    //
    // Collection: courses/{courseId}/modules
    // Document ID: moduleId
    // Fields: id, courseId, title, type, contentUrl, order
    //
    // Collection: courses/{courseId}/assessments
    // Document ID: assessmentId
    // Fields: id, courseId, title, description, passingScore, timeLimit, proctoringEnabled, allowedAttempts, questions
    //
    // Collection: mockTests
    // Document ID: testId
    // Fields: id, title, description, category, passingScore, timeLimit, proctoringEnabled, questions, published
    //
    // Collection: placements
    // Document ID: placementId
    // Fields: id, companyName, role, description, location, companyType, applicationsOpen, applyLink, recruitmentProcess, employabilityGuide, postedAt
    //
    // Collection: applications
    // Document ID: applicationId
    // Fields: id, placementId, studentId, studentName, status, appliedAt
    //
    // Collection: certificates
    // Document ID: certId
    // Fields: id, studentId, studentName, courseId, courseTitle, issuedAt, certificateNumber
    //
    // Collection: enrollments
    // Document ID: enrollmentId
    // Fields: id, studentId, courseId, progress, completedModules, status, enrolledAt
    //
    // Collection: contactMessages
    // Document ID: messageId
    // Fields: id, name, email, message, createdAt
    //
    // Collection: pageContent
    // Document ID: pageId
    // Fields: id, page, sections
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "sunokahaniyanofficial@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isFaculty() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'faculty';
    }

    function isPlacement() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'placement';
    }

    function isStudent() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && data.email is string && data.role in ['admin', 'faculty', 'placement', 'student'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isFaculty();
      allow update: if isAdmin() || (isFaculty() && resource.data.facultyId == request.auth.uid);
      allow delete: if isAdmin() || (isFaculty() && resource.data.facultyId == request.auth.uid);

      match /modules/{moduleId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || (isFaculty() && get(/databases/$(database)/documents/courses/$(courseId)).data.facultyId == request.auth.uid);
      }

      match /assessments/{assessmentId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || (isFaculty() && get(/databases/$(database)/documents/courses/$(courseId)).data.facultyId == request.auth.uid);
      }
    }

    match /mockTests/{testId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isFaculty();
    }

    match /placements/{placementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isPlacement();
    }

    match /applications/{applicationId} {
      allow read: if isAdmin() || isPlacement() || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin() || isPlacement();
      allow delete: if isAdmin();
    }

    match /certificates/{certId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isFaculty();
      allow delete: if isAdmin();
    }

    match /enrollments/{enrollmentId} {
      allow read: if isAdmin() || isFaculty() || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin() || isFaculty() || (isStudent() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /contactMessages/{messageId} {
      allow read: if isAdmin();
      allow create: if true; // Allow anyone to send contact messages
      allow delete: if isAdmin();
    }

    match /pageContent/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
